{
  "expo": {
    "name": "Slumber",
    "slug": "slumber-sleep-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "slumber",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C18"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.slumber.sleeptracker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.slumber.sleeptracker",
      "adaptiveIcon": {
        "backgroundColor": "#080C18",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      ["@kingstinct/react-native-healthkit", {
        "NSHealthShareUsageDescription": "Slumber analyzes your step count, ambient sound levels, and headphone usage to automatically detect when you're asleep — no manual logging needed."
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "4adcbc0a-b4d8-49e4-931d-6e345cfcdf3f"
      }
    },
    "owner": "nilayr"
  }
}
